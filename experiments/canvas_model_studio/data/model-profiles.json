[
  {
    "id": "sdxl-comfy-base",
    "name": "本地 SDXL 基础生图",
    "group": "本地 ComfyUI",
    "description": "通用文生图参数档案，字段对齐 ComfyUI 的 CheckpointLoader + KSampler。",
    "task": "text-to-image",
    "engine": "comfy_sdxl",
    "mediaType": "image",
    "parameters": {
      "checkpoint": "",
      "width": 1024,
      "height": 1024,
      "steps": 24,
      "cfg": 7,
      "sampler": "euler",
      "scheduler": "normal",
      "denoise": 1,
      "batchSize": 1,
      "negative": "low quality, blurry, distorted"
    },
    "fields": []
  },
  {
    "id": "tikpan-gpt-image-2",
    "name": "GPT Image 2 官方生图",
